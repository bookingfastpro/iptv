# URL publique du proxy (accessible depuis le navigateur des utilisateurs)
# En dev local : laisser vide (utilise http://localhost:4000 par défaut)
# En production Coolify : mettre l'URL publique du service proxy
VITE_PROXY_URL=https://proxy.mondomaine.com

# Ports exposés (optionnel)
PWA_PORT=3000
PROXY_PORT=4000
